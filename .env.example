# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

PORT=3000

# Gmail address used to send form emails
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account
EMAIL_APP_PASS=your-16-character-app-password

# Where to receive consultation requests
EMAIL_TO=yoav@dr-yoav-shechter.com
